# Copy to .env and fill in. .env is gitignored — never commit real credentials.

# Spotify Web API — create an app at https://developer.spotify.com/dashboard
# Redirect URI registered in the app must match config/default.yaml (spotify.redirect_uri).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Last.fm — optional, only needed for the tag-graph crawler fallback (Phase 4).
LASTFM_API_KEY=
LASTFM_API_SECRET=
